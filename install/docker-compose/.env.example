# sparkwing docker-compose config.
# Copy to `.env` and fill in your values. Do NOT commit .env.

# -------- required --------

# Bearer token for the sparkwing API. All remote runners need this.
# Generate with: head -c 48 /dev/urandom | base64 | tr -d '=+/' | head -c 40
SPARKWING_API_TOKEN=changeme-generate-a-random-token

# GitHub webhook shared secret. Set this in your GitHub webhook config too.
# Generate with: head -c 32 /dev/urandom | base64 | tr -d '=+/' | head -c 40
GITHUB_WEBHOOK_SECRET=changeme-generate-a-random-webhook-secret

# Public hostnames for the services. You'll point DNS at your host
# and configure a reverse proxy (Caddy/Traefik/nginx) to terminate TLS
# and route to the container ports. The values below just need to match
# whatever you configure in the reverse proxy and DNS.
LOGS_PUBLIC_URL=https://logs.example.com
DASHBOARD_URL=https://sparkwing.example.com

# -------- optional --------

# GitHub token for posting status checks on PRs. Needs `repo:status`
# scope. Leave unset to skip status check posting.
# GITHUB_TOKEN=ghp_xxxxxxxxxxxx

# How long logs are retained before the cleanup loop deletes them.
# LOGS_RETENTION=168h  # 7 days, the default

# Path to an SSH private key the cache can use to clone private
# repos. Mounted read-only into the cache container at /etc/ssh-key.
# Directory must contain id_ed25519 + known_hosts files.
# SSH_KEY_PATH=./ssh-key
